# Copy to .env (git-ignored) and fill in the keys you have.
# Bun loads .env automatically, so live tests pick these up:
#
#   LIVE=1 bun test live
#
# Keyless providers (qrandom.io, lfdr, drand, nist-beacon, anu-legacy) need no
# key — each keyed provider below is tested only when its variable is set.

# ANU Quantum Numbers (keyed API) — subscribe via AWS Marketplace:
# https://aws.amazon.com/marketplace/pp/prodview-246kyrfjo3bag
ANU_API_KEY=

# Outshift by Cisco QRNG — free signup (Cisco account), 100k bits/day:
# https://qrng.outshift.com
OUTSHIFT_API_KEY=

# Quantum Computing Inc. uQRNG — API token via their access portal (email approval):
# https://quantumcomputinginc.com/learn/developer-resources/quantum-random-number-generation/qrng-api-quickstart-guide
QCI_API_TOKEN=

# RANDOM.ORG JSON-RPC API — free Developer key (1000 req/day, 250k bits/day):
# https://api.random.org/dashboard
RANDOM_ORG_API_KEY=

# SuperRand — free 512 KiB on signup; also verifies the WebSocket stream:
# https://portal.super-rand.io/signup
SUPERRAND_API_KEY=
