{
  "files": {
    "includes": ["packages/**", "!**/dist", "!**/.claude-flow", "!**/.claude"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
